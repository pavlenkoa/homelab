{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended",
    "helpers:pinGitHubActionDigests",
    "docker:pinDigests",
    "security:openssf-scorecard"
  ],

  // Helm charts - Renovate updates Chart.yaml versions, ArgoCD fetches at sync time
  "helmv3": {
    "fileMatch": ["kubernetes/apps/.*/Chart\\.yaml$"]
  },

  // Raw K8s manifests - scan image: references in directory apps (transmission, soju, gamja, etc.)
  // Skip Helm templates — Go template interpolation breaks digest pinning
  "kubernetes": {
    "fileMatch": ["kubernetes/apps/.*\\.ya?ml$"],
    "ignorePaths": ["**/templates/**"]
  },

  // Schedule & Limits
  "schedule": ["before 6am on monday"],
  "timezone": "Europe/Kyiv",
  "prHourlyLimit": 2,
  "prConcurrentLimit": 5,

  // Stability - wait 3 days before updating to fresh releases
  "minimumReleaseAge": "3 days",

  // Automerge (Renovate-managed, not GitHub's native automerge)
  "automerge": true,
  "platformAutomerge": false,

  // Labels
  "labels": ["dependencies"],

  // Security
  "osvVulnerabilityAlerts": true,
  "vulnerabilityAlerts": {
    "enabled": true,
    "labels": ["security"],
    "minimumReleaseAge": null
  },

  // Package Rules
  "packageRules": [
    {
      "description": "Group Helm chart updates",
      "matchManagers": ["helmv3"],
      "matchFileNames": ["kubernetes/apps/**"],
      "groupName": "Helm charts",
      "commitMessagePrefix": "chore(helm):"
    },
    {
      "description": "Group GitHub Actions updates",
      "matchManagers": ["github-actions"],
      "groupName": "GitHub Actions"
    },
    {
      "description": "Group Docker images",
      "matchManagers": ["dockerfile"],
      "groupName": "Docker images"
    },
    {
      "description": "Don't automerge major updates",
      "matchUpdateTypes": ["major"],
      "automerge": false
    },
    {
      "description": "Skip kgateway envoy-wrapper - version must match chart appVersion",
      "matchManagers": ["helm-values"],
      "matchFileNames": ["kubernetes/apps/kgateway/**"],
      "enabled": false
    },
    {
      "description": "Skip stability wait for digest updates - digests are immutable",
      "matchUpdateTypes": ["digest", "pinDigest", "pin"],
      "minimumReleaseAge": null
    }
  ]
}
