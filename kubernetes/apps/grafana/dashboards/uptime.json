{
  "id": null,
  "uid": "uptime-overview",
  "title": "Uptime",
  "tags": ["blackbox", "uptime"],
  "timezone": "browser",
  "refresh": "1m",
  "time": { "from": "now-24h", "to": "now" },
  "templating": { "list": [] },
  "panels": [
    {
      "title": "Overview",
      "type": "row",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "collapsed": false
    },
    {
      "title": "Total Monitors",
      "type": "stat",
      "gridPos": { "h": 4, "w": 3, "x": 0, "y": 1 },
      "datasource": { "type": "prometheus", "uid": "P4169E866C3094E38" },
      "targets": [{ "expr": "count(probe_success{job=\"blackbox\"})", "refId": "A", "instant": true }],
      "fieldConfig": { "defaults": { "thresholds": { "steps": [{ "color": "purple", "value": null }] } } },
      "options": { "reduceOptions": { "calcs": ["last"] }, "colorMode": "background", "textMode": "value" }
    },
    {
      "title": "UP",
      "type": "stat",
      "gridPos": { "h": 4, "w": 3, "x": 3, "y": 1 },
      "datasource": { "type": "prometheus", "uid": "P4169E866C3094E38" },
      "targets": [{ "expr": "count(probe_success{job=\"blackbox\"} == 1)", "refId": "A", "instant": true }],
      "fieldConfig": { "defaults": { "thresholds": { "steps": [{ "color": "green", "value": null }] } } },
      "options": { "reduceOptions": { "calcs": ["last"] }, "colorMode": "background", "textMode": "value" }
    },
    {
      "title": "DOWN",
      "type": "stat",
      "gridPos": { "h": 4, "w": 3, "x": 6, "y": 1 },
      "datasource": { "type": "prometheus", "uid": "P4169E866C3094E38" },
      "targets": [{ "expr": "count(probe_success{job=\"blackbox\"} == 0) OR vector(0)", "refId": "A", "instant": true }],
      "fieldConfig": { "defaults": { "thresholds": { "steps": [{ "color": "green", "value": null }, { "color": "red", "value": 1 }] } } },
      "options": { "reduceOptions": { "calcs": ["last"] }, "colorMode": "background", "textMode": "value" }
    },
    {
      "title": "Certs ≤ 7d",
      "type": "stat",
      "gridPos": { "h": 4, "w": 3, "x": 9, "y": 1 },
      "datasource": { "type": "prometheus", "uid": "P4169E866C3094E38" },
      "targets": [{ "expr": "count((probe_ssl_earliest_cert_expiry{job=\"blackbox\"} - time()) / 86400 <= 7) OR vector(0)", "refId": "A", "instant": true }],
      "fieldConfig": { "defaults": { "thresholds": { "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 1 }] } } },
      "options": { "reduceOptions": { "calcs": ["last"] }, "colorMode": "background", "textMode": "value" }
    },
    {
      "title": "Avg Response",
      "type": "stat",
      "gridPos": { "h": 4, "w": 3, "x": 12, "y": 1 },
      "datasource": { "type": "prometheus", "uid": "P4169E866C3094E38" },
      "targets": [{ "expr": "avg(probe_duration_seconds{job=\"blackbox\"}) * 1000", "refId": "A", "instant": true }],
      "fieldConfig": { "defaults": { "unit": "ms", "decimals": 0, "thresholds": { "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 500 }, { "color": "red", "value": 2000 }] } } },
      "options": { "reduceOptions": { "calcs": ["last"] }, "colorMode": "value", "textMode": "value" }
    },
    {
      "title": "Avg Uptime",
      "type": "stat",
      "gridPos": { "h": 4, "w": 3, "x": 15, "y": 1 },
      "datasource": { "type": "prometheus", "uid": "P4169E866C3094E38" },
      "targets": [{ "expr": "avg(avg_over_time(probe_success{job=\"blackbox\"}[$__range]))", "refId": "A", "instant": true }],
      "fieldConfig": { "defaults": { "unit": "percentunit", "decimals": 2, "thresholds": { "steps": [{ "color": "red", "value": null }, { "color": "yellow", "value": 0.95 }, { "color": "green", "value": 0.99 }] } } },
      "options": { "reduceOptions": { "calcs": ["last"] }, "colorMode": "background", "textMode": "value" }
    },
    {
      "title": "Uptime 7d",
      "type": "stat",
      "gridPos": { "h": 4, "w": 3, "x": 18, "y": 1 },
      "datasource": { "type": "prometheus", "uid": "P4169E866C3094E38" },
      "targets": [{ "expr": "avg(avg_over_time(probe_success{job=\"blackbox\"}[7d]))", "refId": "A", "instant": true }],
      "fieldConfig": { "defaults": { "unit": "percentunit", "decimals": 2, "thresholds": { "steps": [{ "color": "red", "value": null }, { "color": "yellow", "value": 0.95 }, { "color": "green", "value": 0.99 }] } } },
      "options": { "reduceOptions": { "calcs": ["last"] }, "colorMode": "background", "textMode": "value" }
    },
    {
      "title": "Uptime 30d",
      "type": "stat",
      "gridPos": { "h": 4, "w": 3, "x": 21, "y": 1 },
      "datasource": { "type": "prometheus", "uid": "P4169E866C3094E38" },
      "targets": [{ "expr": "avg(avg_over_time(probe_success{job=\"blackbox\"}[30d]))", "refId": "A", "instant": true }],
      "fieldConfig": { "defaults": { "unit": "percentunit", "decimals": 2, "thresholds": { "steps": [{ "color": "red", "value": null }, { "color": "yellow", "value": 0.95 }, { "color": "green", "value": 0.99 }] } } },
      "options": { "reduceOptions": { "calcs": ["last"] }, "colorMode": "background", "textMode": "value" }
    },
    {
      "title": "Monitor Status",
      "type": "row",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 5 },
      "collapsed": false
    },
    {
      "title": "Monitor Status Overview",
      "type": "table",
      "gridPos": { "h": 12, "w": 24, "x": 0, "y": 6 },
      "datasource": { "type": "prometheus", "uid": "P4169E866C3094E38" },
      "targets": [
        { "expr": "probe_success{job=\"blackbox\"}", "refId": "status", "instant": true, "format": "table" },
        { "expr": "probe_duration_seconds{job=\"blackbox\"} * 1000", "refId": "latency", "instant": true, "format": "table" },
        { "expr": "(probe_ssl_earliest_cert_expiry{job=\"blackbox\"} - time()) / 86400", "refId": "cert", "instant": true, "format": "table" },
        { "expr": "avg_over_time(probe_success{job=\"blackbox\"}[$__range]) * 100", "refId": "uptime", "instant": true, "format": "table" },
        { "expr": "probe_http_status_code{job=\"blackbox\"}", "refId": "code", "instant": true, "format": "table" }
      ],
      "transformations": [
        { "id": "seriesToColumns", "options": { "byField": "instance" } },
        {
          "id": "organize",
          "options": {
            "excludeByName": { "Time 1": true, "Time 2": true, "Time 3": true, "Time 4": true, "Time 5": true, "__name__ 1": true, "__name__ 2": true, "__name__ 3": true, "__name__ 4": true, "__name__ 5": true, "cluster 1": true, "cluster 2": true, "cluster 3": true, "cluster 4": true, "cluster 5": true, "job 1": true, "job 2": true, "job 3": true, "job 4": true, "job 5": true },
            "renameByName": { "instance": "Service", "Value #status": "Status", "Value #latency": "Response (ms)", "Value #cert": "Cert Days", "Value #uptime": "Uptime %", "Value #code": "HTTP" },
            "indexByName": { "instance": 0, "Value #status": 1, "Value #latency": 2, "Value #cert": 3, "Value #uptime": 4, "Value #code": 5 }
          }
        }
      ],
      "fieldConfig": {
        "defaults": { "custom": { "align": "left" } },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "Status" },
            "properties": [
              { "id": "mappings", "value": [{ "type": "value", "options": { "0": { "text": "DOWN", "color": "red" }, "1": { "text": "UP", "color": "green" } } }] },
              { "id": "custom.cellOptions", "value": { "type": "color-background" } },
              { "id": "custom.width", "value": 70 }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "Response (ms)" },
            "properties": [
              { "id": "decimals", "value": 0 },
              { "id": "custom.width", "value": 120 },
              { "id": "thresholds", "value": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 500 }, { "color": "red", "value": 2000 }] } },
              { "id": "custom.cellOptions", "value": { "type": "color-text" } }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "Cert Days" },
            "properties": [
              { "id": "decimals", "value": 0 },
              { "id": "custom.width", "value": 100 },
              { "id": "thresholds", "value": { "mode": "absolute", "steps": [{ "color": "red", "value": null }, { "color": "yellow", "value": 7 }, { "color": "green", "value": 30 }] } },
              { "id": "custom.cellOptions", "value": { "type": "color-text" } }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "Uptime %" },
            "properties": [
              { "id": "decimals", "value": 2 },
              { "id": "custom.width", "value": 100 },
              { "id": "thresholds", "value": { "mode": "absolute", "steps": [{ "color": "red", "value": null }, { "color": "yellow", "value": 95 }, { "color": "green", "value": 99 }] } },
              { "id": "custom.cellOptions", "value": { "type": "color-text" } }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "HTTP" },
            "properties": [
              { "id": "decimals", "value": 0 },
              { "id": "custom.width", "value": 70 }
            ]
          }
        ]
      }
    },
    {
      "title": "Uptime",
      "type": "row",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 18 },
      "collapsed": false,
      "panels": [
        {
          "title": "Status – Live",
          "type": "state-timeline",
          "gridPos": { "h": 12, "w": 24, "x": 0, "y": 19 },
          "datasource": { "type": "prometheus", "uid": "P4169E866C3094E38" },
          "targets": [
            { "expr": "min_over_time(probe_success{job=\"blackbox\"}[5m])", "refId": "A", "legendFormat": "{{ instance }}", "interval": "5m" }
          ],
          "maxDataPoints": 100,
          "fieldConfig": {
            "defaults": {
              "mappings": [
                { "type": "value", "options": { "0": { "text": "DOWN", "color": "red" } } },
                { "type": "value", "options": { "1": { "text": "UP", "color": "green" } } }
              ],
              "thresholds": { "steps": [{ "color": "red", "value": null }, { "color": "green", "value": 1 }] },
              "custom": { "fillOpacity": 100, "lineWidth": 1 }
            }
          },
          "options": { "showValue": "never", "mergeValues": false, "rowHeight": 0.7, "tooltip": { "mode": "single" }, "legend": { "displayMode": "hidden" } },
          "transformations": [
            { "id": "renameByRegex", "options": { "regex": "https://(.+)\\.pavlenko\\.io", "renamePattern": "$1" } }
          ]
        },
        {
          "title": "Uptime per Monitor",
          "type": "bargauge",
          "gridPos": { "h": 10, "w": 24, "x": 0, "y": 31 },
          "datasource": { "type": "prometheus", "uid": "P4169E866C3094E38" },
          "targets": [{ "expr": "avg_over_time(probe_success{job=\"blackbox\"}[$__range]) * 100", "refId": "A", "instant": true, "legendFormat": "{{ instance }}" }],
          "fieldConfig": { "defaults": { "unit": "percent", "decimals": 2, "min": 0, "max": 100, "thresholds": { "steps": [{ "color": "red", "value": null }, { "color": "yellow", "value": 95 }, { "color": "green", "value": 99 }] } } },
          "options": { "orientation": "horizontal", "displayMode": "gradient", "reduceOptions": { "calcs": ["lastNotNull"] } },
          "transformations": [
            { "id": "renameByRegex", "options": { "regex": "https://(.+)\\.pavlenko\\.io", "renamePattern": "$1" } }
          ]
        }
      ]
    },
    {
      "title": "Response Time",
      "type": "row",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 19 },
      "collapsed": false,
      "panels": [
        {
          "title": "Response Time – Live",
          "type": "timeseries",
          "gridPos": { "h": 10, "w": 24, "x": 0, "y": 20 },
          "datasource": { "type": "prometheus", "uid": "P4169E866C3094E38" },
          "targets": [{ "expr": "probe_duration_seconds{job=\"blackbox\"}", "refId": "A", "legendFormat": "{{ instance }}" }],
          "fieldConfig": { "defaults": { "unit": "s", "custom": { "drawStyle": "line", "lineWidth": 1, "fillOpacity": 10, "showPoints": "never" } } },
          "transformations": [
            { "id": "renameByRegex", "options": { "regex": "https://(.+)\\.pavlenko\\.io", "renamePattern": "$1" } }
          ],
          "options": { "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["mean", "max"] }, "tooltip": { "mode": "multi" } }
        },
        {
          "title": "Avg Response Time per Monitor",
          "type": "bargauge",
          "gridPos": { "h": 8, "w": 24, "x": 0, "y": 30 },
          "datasource": { "type": "prometheus", "uid": "P4169E866C3094E38" },
          "targets": [{ "expr": "avg_over_time(probe_duration_seconds{job=\"blackbox\"}[$__range]) * 1000", "refId": "A", "instant": true, "legendFormat": "{{ instance }}" }],
          "fieldConfig": { "defaults": { "unit": "ms", "decimals": 0, "thresholds": { "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 500 }, { "color": "red", "value": 2000 }] } } },
          "options": { "orientation": "horizontal", "displayMode": "gradient", "reduceOptions": { "calcs": ["lastNotNull"] } },
          "transformations": [
            { "id": "renameByRegex", "options": { "regex": "https://(.+)\\.pavlenko\\.io", "renamePattern": "$1" } }
          ]
        }
      ]
    },
    {
      "title": "SSL Certificates",
      "type": "row",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 20 },
      "collapsed": true,
      "panels": [
        {
          "title": "Certificate Days Remaining",
          "type": "bargauge",
          "gridPos": { "h": 10, "w": 24, "x": 0, "y": 21 },
          "datasource": { "type": "prometheus", "uid": "P4169E866C3094E38" },
          "targets": [{ "expr": "(probe_ssl_earliest_cert_expiry{job=\"blackbox\"} - time()) / 86400", "refId": "A", "instant": true, "legendFormat": "{{ instance }}" }],
          "fieldConfig": { "defaults": { "unit": "d", "decimals": 0, "thresholds": { "mode": "absolute", "steps": [{ "color": "red", "value": null }, { "color": "yellow", "value": 7 }, { "color": "green", "value": 30 }] } } },
          "options": { "orientation": "horizontal", "displayMode": "gradient", "reduceOptions": { "calcs": ["lastNotNull"] } },
          "transformations": [
            { "id": "renameByRegex", "options": { "regex": "https://(.+)\\.pavlenko\\.io", "renamePattern": "$1" } }
          ]
        }
      ]
    }
  ],
  "schemaVersion": 39
}
