{
  "id": null,
  "uid": "uptime-overview",
  "title": "Uptime",
  "tags": ["blackbox", "uptime"],
  "timezone": "browser",
  "refresh": "1m",
  "time": { "from": "now-24h", "to": "now" },
  "templating": {
    "list": [
      {
        "name": "service",
        "type": "query",
        "datasource": { "type": "prometheus", "uid": "P4169E866C3094E38" },
        "query": { "query": "label_values(probe_success{job=\"blackbox\"}, instance)", "refId": "StandardVariableQuery" },
        "definition": "label_values(probe_success{job=\"blackbox\"}, instance)",
        "refresh": 2,
        "sort": 1,
        "multi": false,
        "includeAll": false,
        "regex": "/https:\\/\\/(.+)\\.pavlenko\\.io/",
        "hide": 0,
        "skipUrlSync": false
      }
    ]
  },
  "panels": [
    {
      "title": "All Services",
      "type": "state-timeline",
      "gridPos": { "h": 10, "w": 24, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "P4169E866C3094E38" },
      "targets": [
        { "expr": "min_over_time(probe_success{job=\"blackbox\"}[5m])", "refId": "A", "legendFormat": "{{ instance }}", "interval": "5m" }
      ],
      "maxDataPoints": 100,
      "fieldConfig": {
        "defaults": {
          "mappings": [
            { "type": "value", "options": { "0": { "text": "DOWN", "color": "red" } } },
            { "type": "value", "options": { "1": { "text": "UP", "color": "green" } } }
          ],
          "thresholds": { "steps": [{ "color": "red", "value": null }, { "color": "green", "value": 1 }] },
          "custom": { "fillOpacity": 100, "lineWidth": 1 }
        }
      },
      "options": {
        "showValue": "never",
        "mergeValues": false,
        "rowHeight": 0.7,
        "tooltip": { "mode": "single" },
        "legend": { "displayMode": "hidden" }
      },
      "transformations": [
        { "id": "renameByRegex", "options": { "regex": "https://(.+)\\.pavlenko\\.io", "renamePattern": "$1" } }
      ]
    },
    {
      "title": "",
      "type": "row",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 10 },
      "collapsed": false,
      "panels": []
    },
    {
      "title": "Status",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 0, "y": 11 },
      "datasource": { "type": "prometheus", "uid": "P4169E866C3094E38" },
      "targets": [{ "expr": "probe_success{instance=~\"https://$service\\\\.pavlenko\\\\.io\"}", "refId": "A", "instant": true }],
      "fieldConfig": {
        "defaults": {
          "mappings": [{ "type": "value", "options": { "0": { "text": "DOWN", "color": "red" }, "1": { "text": "UP", "color": "green" } } }],
          "thresholds": { "steps": [{ "color": "red", "value": null }, { "color": "green", "value": 1 }] }
        }
      },
      "options": { "reduceOptions": { "calcs": ["last"] }, "colorMode": "background", "textMode": "value" }
    },
    {
      "title": "Avg Response",
      "type": "stat",
      "gridPos": { "h": 4, "w": 5, "x": 4, "y": 11 },
      "datasource": { "type": "prometheus", "uid": "P4169E866C3094E38" },
      "targets": [{ "expr": "avg_over_time(probe_duration_seconds{instance=~\"https://$service\\\\.pavlenko\\\\.io\"}[$__range])", "refId": "A", "instant": true }],
      "fieldConfig": { "defaults": { "unit": "ms", "thresholds": { "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 500 }, { "color": "red", "value": 2000 }] } } },
      "options": { "reduceOptions": { "calcs": ["last"] }, "colorMode": "value", "textMode": "value" },
      "transformations": [
        { "id": "calculateField", "options": { "mode": "reduceRow", "reduce": { "reducer": "last" } } },
        { "id": "organize", "options": { "excludeByName": {} } }
      ]
    },
    {
      "title": "Uptime 24h",
      "type": "stat",
      "gridPos": { "h": 4, "w": 5, "x": 9, "y": 11 },
      "datasource": { "type": "prometheus", "uid": "P4169E866C3094E38" },
      "targets": [{ "expr": "avg_over_time(probe_success{instance=~\"https://$service\\\\.pavlenko\\\\.io\"}[24h])", "refId": "A", "instant": true }],
      "fieldConfig": { "defaults": { "unit": "percentunit", "decimals": 2, "thresholds": { "steps": [{ "color": "red", "value": null }, { "color": "yellow", "value": 0.95 }, { "color": "green", "value": 0.99 }] } } },
      "options": { "reduceOptions": { "calcs": ["last"] }, "colorMode": "value", "textMode": "value" }
    },
    {
      "title": "Uptime 30d",
      "type": "stat",
      "gridPos": { "h": 4, "w": 5, "x": 14, "y": 11 },
      "datasource": { "type": "prometheus", "uid": "P4169E866C3094E38" },
      "targets": [{ "expr": "avg_over_time(probe_success{instance=~\"https://$service\\\\.pavlenko\\\\.io\"}[30d])", "refId": "A", "instant": true }],
      "fieldConfig": { "defaults": { "unit": "percentunit", "decimals": 2, "thresholds": { "steps": [{ "color": "red", "value": null }, { "color": "yellow", "value": 0.95 }, { "color": "green", "value": 0.99 }] } } },
      "options": { "reduceOptions": { "calcs": ["last"] }, "colorMode": "value", "textMode": "value" }
    },
    {
      "title": "HTTP Code",
      "type": "stat",
      "gridPos": { "h": 4, "w": 5, "x": 19, "y": 11 },
      "datasource": { "type": "prometheus", "uid": "P4169E866C3094E38" },
      "targets": [{ "expr": "probe_http_status_code{instance=~\"https://$service\\\\.pavlenko\\\\.io\"}", "refId": "A", "instant": true }],
      "fieldConfig": { "defaults": { "decimals": 0, "thresholds": { "steps": [{ "color": "green", "value": null }, { "color": "red", "value": 500 }] } } },
      "options": { "reduceOptions": { "calcs": ["last"] }, "colorMode": "value", "textMode": "value" }
    },
    {
      "title": "Response Time — $service",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 15 },
      "datasource": { "type": "prometheus", "uid": "P4169E866C3094E38" },
      "targets": [{ "expr": "probe_duration_seconds{instance=~\"https://$service\\\\.pavlenko\\\\.io\"}", "refId": "A", "legendFormat": "Response Time" }],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "custom": { "drawStyle": "line", "lineWidth": 2, "fillOpacity": 15, "gradientMode": "opacity", "showPoints": "never" },
          "color": { "mode": "fixed", "fixedColor": "green" },
          "thresholds": { "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 1 }, { "color": "red", "value": 5 }] }
        }
      },
      "options": { "legend": { "displayMode": "list", "placement": "bottom", "calcs": ["min", "mean", "max"] }, "tooltip": { "mode": "single" } }
    },
    {
      "title": "All Services Summary",
      "type": "table",
      "gridPos": { "h": 10, "w": 24, "x": 0, "y": 23 },
      "datasource": { "type": "prometheus", "uid": "P4169E866C3094E38" },
      "targets": [
        { "expr": "probe_success{job=\"blackbox\"}", "refId": "status", "instant": true, "format": "table" },
        { "expr": "avg_over_time(probe_success{job=\"blackbox\"}[24h])", "refId": "uptime24h", "instant": true, "format": "table" },
        { "expr": "avg_over_time(probe_success{job=\"blackbox\"}[30d])", "refId": "uptime30d", "instant": true, "format": "table" },
        { "expr": "probe_duration_seconds{job=\"blackbox\"}", "refId": "latency", "instant": true, "format": "table" },
        { "expr": "probe_http_status_code{job=\"blackbox\"}", "refId": "code", "instant": true, "format": "table" }
      ],
      "transformations": [
        { "id": "seriesToColumns", "options": { "byField": "instance" } },
        {
          "id": "organize",
          "options": {
            "excludeByName": { "Time 1": true, "Time 2": true, "Time 3": true, "Time 4": true, "Time 5": true, "__name__ 1": true, "__name__ 2": true, "__name__ 3": true, "__name__ 4": true, "__name__ 5": true, "cluster 1": true, "cluster 2": true, "cluster 3": true, "cluster 4": true, "cluster 5": true, "job 1": true, "job 2": true, "job 3": true, "job 4": true, "job 5": true },
            "renameByName": { "instance": "Service", "Value #status": "Status", "Value #uptime24h": "Uptime 24h", "Value #uptime30d": "Uptime 30d", "Value #latency": "Latency", "Value #code": "HTTP Code" },
            "indexByName": { "instance": 0, "Value #status": 1, "Value #uptime24h": 2, "Value #uptime30d": 3, "Value #code": 4, "Value #latency": 5 }
          }
        }
      ],
      "fieldConfig": {
        "defaults": { "custom": { "align": "left" } },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "Service" },
            "properties": [{ "id": "custom.width", "value": 280 }]
          },
          {
            "matcher": { "id": "byName", "options": "Status" },
            "properties": [
              { "id": "mappings", "value": [{ "type": "value", "options": { "0": { "text": "DOWN", "color": "red" }, "1": { "text": "UP", "color": "green" } } }] },
              { "id": "custom.cellOptions", "value": { "type": "color-background" } },
              { "id": "custom.width", "value": 80 }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "Uptime 24h" },
            "properties": [
              { "id": "unit", "value": "percentunit" },
              { "id": "decimals", "value": 2 },
              { "id": "thresholds", "value": { "mode": "absolute", "steps": [{ "color": "red", "value": null }, { "color": "yellow", "value": 0.95 }, { "color": "green", "value": 0.99 }] } },
              { "id": "custom.cellOptions", "value": { "type": "color-text" } },
              { "id": "custom.width", "value": 110 }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "Uptime 30d" },
            "properties": [
              { "id": "unit", "value": "percentunit" },
              { "id": "decimals", "value": 2 },
              { "id": "thresholds", "value": { "mode": "absolute", "steps": [{ "color": "red", "value": null }, { "color": "yellow", "value": 0.95 }, { "color": "green", "value": 0.99 }] } },
              { "id": "custom.cellOptions", "value": { "type": "color-text" } },
              { "id": "custom.width", "value": 110 }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "Latency" },
            "properties": [
              { "id": "unit", "value": "s" },
              { "id": "decimals", "value": 3 },
              { "id": "custom.width", "value": 100 }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "HTTP Code" },
            "properties": [
              { "id": "decimals", "value": 0 },
              { "id": "custom.width", "value": 100 }
            ]
          }
        ]
      }
    }
  ],
  "schemaVersion": 39
}
