{
  "id": null,
  "uid": "uptime-overview",
  "title": "Uptime",
  "tags": ["blackbox", "uptime"],
  "timezone": "browser",
  "refresh": "1m",
  "time": { "from": "now-24h", "to": "now" },
  "templating": { "list": [] },
  "panels": [
    {
      "title": "Service Status",
      "type": "status-history",
      "gridPos": { "h": 14, "w": 24, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "P4169E866C3094E38" },
      "targets": [
        { "expr": "min_over_time(probe_success{job=\"blackbox\"}[5m])", "refId": "A", "legendFormat": "{{ instance }}", "interval": "5m" }
      ],
      "maxDataPoints": 100,
      "fieldConfig": {
        "defaults": {
          "mappings": [
            { "type": "value", "options": { "0": { "text": "DOWN", "color": "red" } } },
            { "type": "value", "options": { "1": { "text": "UP", "color": "green" } } }
          ],
          "thresholds": { "steps": [{ "color": "red", "value": null }, { "color": "green", "value": 1 }] },
          "custom": { "fillOpacity": 100 }
        },
        "overrides": []
      },
      "options": {
        "showValue": "never",
        "rowHeight": 0.8,
        "tooltip": { "mode": "single" },
        "legend": { "displayMode": "hidden" }
      },
      "transformations": [
        {
          "id": "renameByRegex",
          "options": { "regex": "https://(.+)\\.pavlenko\\.io", "renamePattern": "$1" }
        }
      ]
    },
    {
      "title": "Current Status & Uptime",
      "type": "table",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 14 },
      "datasource": { "type": "prometheus", "uid": "P4169E866C3094E38" },
      "targets": [
        { "expr": "probe_success{job=\"blackbox\"}", "refId": "status", "instant": true, "format": "table" },
        { "expr": "avg_over_time(probe_success{job=\"blackbox\"}[$__range])", "refId": "uptime", "instant": true, "format": "table" },
        { "expr": "probe_duration_seconds{job=\"blackbox\"}", "refId": "latency", "instant": true, "format": "table" },
        { "expr": "probe_http_status_code{job=\"blackbox\"}", "refId": "code", "instant": true, "format": "table" }
      ],
      "transformations": [
        { "id": "seriesToColumns", "options": { "byField": "instance" } },
        {
          "id": "organize",
          "options": {
            "excludeByName": { "Time 1": true, "Time 2": true, "Time 3": true, "Time 4": true, "__name__ 1": true, "__name__ 2": true, "__name__ 3": true, "__name__ 4": true, "cluster 1": true, "cluster 2": true, "cluster 3": true, "cluster 4": true, "job 1": true, "job 2": true, "job 3": true, "job 4": true },
            "renameByName": { "instance": "Service", "Value #status": "Status", "Value #uptime": "Uptime", "Value #latency": "Latency", "Value #code": "HTTP Code" },
            "indexByName": { "instance": 0, "Value #status": 1, "Value #uptime": 2, "Value #code": 3, "Value #latency": 4 }
          }
        }
      ],
      "fieldConfig": {
        "defaults": { "custom": { "align": "left" } },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "Status" },
            "properties": [
              { "id": "mappings", "value": [{ "type": "value", "options": { "0": { "text": "DOWN", "color": "red" }, "1": { "text": "UP", "color": "green" } } }] },
              { "id": "custom.cellOptions", "value": { "type": "color-background" } },
              { "id": "custom.width", "value": 80 }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "Uptime" },
            "properties": [
              { "id": "unit", "value": "percentunit" },
              { "id": "decimals", "value": 2 },
              { "id": "thresholds", "value": { "mode": "absolute", "steps": [{ "color": "red", "value": null }, { "color": "yellow", "value": 0.95 }, { "color": "green", "value": 0.99 }] } },
              { "id": "custom.cellOptions", "value": { "type": "color-background" } },
              { "id": "custom.width", "value": 100 }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "Latency" },
            "properties": [
              { "id": "unit", "value": "s" },
              { "id": "decimals", "value": 3 },
              { "id": "custom.width", "value": 100 }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "HTTP Code" },
            "properties": [
              { "id": "decimals", "value": 0 },
              { "id": "custom.width", "value": 100 }
            ]
          }
        ]
      }
    },
    {
      "title": "Response Time",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 22 },
      "datasource": { "type": "prometheus", "uid": "P4169E866C3094E38" },
      "targets": [{ "expr": "probe_duration_seconds{job=\"blackbox\"}", "refId": "A", "legendFormat": "{{ instance }}" }],
      "fieldConfig": { "defaults": { "unit": "s", "custom": { "drawStyle": "line", "lineWidth": 1, "fillOpacity": 10, "showPoints": "never" } } },
      "transformations": [
        { "id": "renameByRegex", "options": { "regex": "https://(.+)\\.pavlenko\\.io", "renamePattern": "$1" } }
      ],
      "options": { "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["mean", "max"] }, "tooltip": { "mode": "multi" } }
    }
  ],
  "schemaVersion": 39
}
